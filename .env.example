# API Configuration
RESEND_API_KEY=your_resend_api_key_here
OWNER_EMAIL=hello@algokami.com

# Optional
NEXT_PUBLIC_SITE_URL=https://algokami.tech
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Resend (server-side email sending) — get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your verified sending domain in Resend
RESEND_FROM_EMAIL=website@yourdomain.com

# Where contact form emails get delivered
RESEND_TO_EMAIL=contact@yourdomain.com

# Neon / Vercel Postgres
# Copy these from your Vercel Postgres or Neon connection settings into .env.local
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname?sslmode=require

# Public variables (safe to expose to browser)
NEXT_PUBLIC_SITE_URL=https://algokami.tech
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
