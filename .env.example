# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Resend (server-side email sending) — get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your verified sending domain in Resend
RESEND_FROM_EMAIL=website@yourdomain.com

# Where contact form emails get delivered
RESEND_TO_EMAIL=contact@yourdomain.com

# Google Sheets (free lead storage for /get-quote form)
# Share your sheet with GOOGLE_SHEETS_CLIENT_EMAIL as Editor
# Option A (easiest, no Google Cloud service account):
# GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/XXXXX/exec

# Option B (service account based):
GOOGLE_SHEETS_SPREADSHEET_ID=1R_xW-trRPPakQMp0TzPGfRBwMR-GYlFaiuANGM-Pybk
GOOGLE_SHEETS_SHEET_NAME=Sheet1
GOOGLE_SHEETS_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Public variables (safe to expose to browser)
NEXT_PUBLIC_SITE_URL=https://algokami.tech
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourusername
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
